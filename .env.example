# Example environment overrides for local runs
SPRING_DATA_MONGODB_URI=mongodb://mongo:27017/agri
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# Agri Marketplace - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<db>?retryWrites=true&w=majority
SPRING_DATA_MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Secret - Must be a valid 256-bit hex string (64 hex characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=<your-256-bit-hex-secret>

# SMTP/Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<your-email@gmail.com>
MAIL_PASSWORD=<your-app-password>

# Payment Gateway Keys
KONNECT_API_KEY=<your-konnect-api-key>
STRIPE_API_KEY=<your-stripe-api-key>

# Docker Registry (optional)
DOCKER_REGISTRY=localhost:5000

# API Gateway Port
API_GATEWAY_PORT=8080

# SonarQube (optional)
SONAR_HOST=
SONAR_TOKEN=
